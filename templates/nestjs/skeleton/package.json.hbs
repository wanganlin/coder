{
  "name": "{{kebabCase projectClassName}}",
  "version": "0.0.1",
  "description": "{{config.target.package}}",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix"
    {{#if features.unitTest}}
    ,"test": "jest",
    "test:cov": "jest --coverage"
    {{/if}}
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "typeorm": "^0.3.20",
    "{{#if (eq config.datasource.type "mysql")}}mysql2{{else}}pg{{/if}}": "^3.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
    {{#if features.swagger}}
    ,"@nestjs/swagger": "^11.0.0"
    {{/if}}
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
    {{#if features.swagger}}
    ,"class-validator": "^0.14.0",
    "class-transformer": "^0.5.0"
    {{/if}}
    {{#if features.unitTest}}
    ,"@nestjs/testing": "^11.0.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0"
    {{/if}}
    ,"eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}
