version: '3.8'

services:
  app:
    build: .
    ports:
      - '9000:9000'
    environment:
      - DB_CONNECTION={{config.datasource.type}}
      - DB_HOST=db
      - DB_PORT={{#if (eq config.datasource.type "mysql")}}3306{{else}}5432{{/if}}
      - DB_DATABASE=appdb
      - DB_USERNAME=root
      - DB_PASSWORD=password
    depends_on:
      - db
    restart: unless-stopped

  web:
    image: nginx:alpine
    ports:
      - '80:80'
    volumes:
      - ./public:/var/www/html/public
      - ./nginx.conf:/etc/nginx/conf.d/default.conf
    depends_on:
      - app

  db:
    {{#if (eq config.datasource.type "mysql")}}
    image: mysql:8.0
    environment:
      MYSQL_ROOT_PASSWORD: password
      MYSQL_DATABASE: appdb
    ports:
      - '3306:3306'
    volumes:
      - db_data:/var/lib/mysql
    {{else}}
    image: postgres:16-alpine
    environment:
      POSTGRES_PASSWORD: password
      POSTGRES_DB: appdb
    ports:
      - '5432:5432'
    volumes:
      - db_data:/var/lib/postgresql/data
    {{/if}}

volumes:
  db_data:
