package handler

import (
	"net/http"
	"strconv"
	"{{propertyName projectClassName}}/db"
	"{{propertyName projectClassName}}/model"
	"github.com/gin-gonic/gin"
)

{{#if features.swagger}}
// Register{{className}}Routes 注册 {{className}} 路由
// @Summary {{className}} CRUD 路由注册
// @Tags {{className}}
{{/if}}
func Register{{className}}Routes(rg *gin.RouterGroup) {
	rg.GET("/{{pluralize propertyName}}", Get{{className}}List)
	rg.GET("/{{pluralize propertyName}}/:id", Get{{className}}ByID)
	rg.POST("/{{pluralize propertyName}}", Create{{className}})
	rg.PUT("/{{pluralize propertyName}}/:id", Update{{className}})
	rg.DELETE("/{{pluralize propertyName}}/:id", Delete{{className}})
}


{{#if features.swagger}}
// Get{{className}}List 获取 {{className}} 分页列表
// @Summary 获取 {{className}} 分页列表
// @Tags {{className}}
// @Produce json
// @Param page query int false "页码" default(0)
// @Param size query int false "每页条数" default(10)
// @Success 200 {object} object{content=[]model.{{className}},totalElements=int,page=int,size=int}
// @Router /{{pluralize propertyName}} [get]
{{/if}}
func Get{{className}}List(c *gin.Context) {
	var items []model.{{className}}

	{{#if features.pagination}}
	page, _ := strconv.Atoi(c.DefaultQuery("page", "0"))
	size, _ := strconv.Atoi(c.DefaultQuery("size", "10"))
	if size <= 0 {
		size = 10
	}
	offset := page * size

	var total int64
	db.DB.Model(&model.{{className}}{}).Count(&total)
	db.DB.Limit(size).Offset(offset).Find(&items)

	c.JSON(http.StatusOK, gin.H{
		"content":       items,
		"totalElements": total,
		"page":          page,
		"size":          size,
	})
	{{else}}
	db.DB.Find(&items)
	c.JSON(http.StatusOK, items)
	{{/if}}
}


{{#if features.swagger}}
// Get{{className}}ByID 根据 ID 获取单个 {{className}}
// @Summary 根据 ID 获取 {{className}}
// @Tags {{className}}
// @Produce json
// @Param id path int true "主键ID"
// @Success 200 {object} model.{{className}}
// @Failure 404 {object} object{error=string}
// @Router /{{pluralize propertyName}}/{id} [get]
{{/if}}
func Get{{className}}ByID(c *gin.Context) {
	{{#each columns}}{{#if isPrimaryKey}}
	{{#if (eq goType "string")}}
	id := c.Param("id")
	{{else}}
	id, err := strconv.ParseInt(c.Param("id"), 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid ID format"})
		return
	}
	{{/if}}
	{{/if}}{{/each}}

	var item model.{{className}}
	if err := db.DB.First(&item, id).Error; err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "{{className}} not found"})
		return
	}

	c.JSON(http.StatusOK, item)
}


{{#if features.swagger}}
// Create{{className}} 创建 {{className}}
// @Summary 创建 {{className}}
// @Tags {{className}}
// @Accept json
// @Produce json
// @Param body body model.Create{{className}}Request true "创建请求"
// @Success 201 {object} model.{{className}}
// @Failure 400 {object} object{error=string}
// @Router /{{pluralize propertyName}} [post]
{{/if}}
func Create{{className}}(c *gin.Context) {
	var req model.Create{{className}}Request
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	item := model.{{className}}{
		{{#each columns}}
		{{#unless isAutoIncrement}}
		{{pascalCase name}}: req.{{pascalCase name}},
		{{/unless}}
		{{/each}}
	}

	if err := db.DB.Create(&item).Error; err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusCreated, item)
}


{{#if features.swagger}}
// Update{{className}} 更新 {{className}}
// @Summary 更新 {{className}}
// @Tags {{className}}
// @Accept json
// @Produce json
// @Param id path int true "主键ID"
// @Param body body model.Update{{className}}Request true "更新请求"
// @Success 200 {object} model.{{className}}
// @Failure 400 {object} object{error=string}
// @Failure 404 {object} object{error=string}
// @Router /{{pluralize propertyName}}/{id} [put]
{{/if}}
func Update{{className}}(c *gin.Context) {
	{{#each columns}}{{#if isPrimaryKey}}
	{{#if (eq goType "string")}}
	id := c.Param("id")
	{{else}}
	id, err := strconv.ParseInt(c.Param("id"), 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid ID format"})
		return
	}
	{{/if}}
	{{/if}}{{/each}}

	var item model.{{className}}
	if err := db.DB.First(&item, id).Error; err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "{{className}} not found"})
		return
	}

	var req model.Update{{className}}Request
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	// 更新属性
	{{#each columns}}
	{{#unless isPrimaryKey}}
	item.{{pascalCase name}} = req.{{pascalCase name}}
	{{/unless}}
	{{/each}}

	if err := db.DB.Save(&item).Error; err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusOK, item)
}


{{#if features.swagger}}
// Delete{{className}} 删除 {{className}}
