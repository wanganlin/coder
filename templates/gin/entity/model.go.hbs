package model

import (
	"time"
)

// {{className}} {{tableComment}}
type {{className}} struct {
	{{#each columns}}
	{{#if (and ../features.auditFields (isAuditField this))}}
	// 审计字段 {{name}} 由中间件/GORM Hooks 自动填充
	{{else}}
	{{pascalCase name}} {{goType}} `gorm:"column:{{name}}{{#if isPrimaryKey}};primaryKey{{#if isAutoIncrement}};autoIncrement{{/if}}{{/if}}{{#unless nullable}};not null{{/unless}}" json:"{{propertyName name}}"`
	{{/if}}
	{{/each}}

	{{#if table.relationships.length}}
	// 关联关系（Coder 自动推导）
	{{#each table.relationships}}
	{{#if (eq type "ManyToOne")}}
	// {{type}}: {{../className}} → {{targetClassName}} (FK: {{#each columnNames}}{{this}}{{/each}})
	{{targetClassName}} {{targetClassName}} `gorm:"foreignKey:{{#each columnNames}}{{pascalCase this}}{{/each}};references:{{#each targetColumns}}{{pascalCase this}}{{/each}}" json:"{{targetPropertyName}}"`
	{{/if}}
	{{#if (eq type "OneToOne")}}
	// {{type}}: {{../className}} → {{targetClassName}}
	{{targetClassName}} {{targetClassName}} `gorm:"foreignKey:{{#each columnNames}}{{pascalCase this}}{{/each}};references:{{#each targetColumns}}{{pascalCase this}}{{/each}};constraint:OnDelete:CASCADE" json:"{{targetPropertyName}}"`
	{{/if}}
	{{#if (eq type "OneToMany")}}
	// {{type}}: {{../className}} ← {{targetClassName}} (mappedBy: {{mappedBy}})
	{{targetPropertyName}}List []{{targetClassName}} `gorm:"foreignKey:{{mappedBy}}" json:"{{targetPropertyName}}List"`
	{{/if}}
	{{#if (eq type "ManyToMany")}}
	// {{type}}: {{../className}} ↔ {{targetClassName}} (联结表: {{mappedBy}})
	{{pluralize targetPropertyName}} []{{targetClassName}} `gorm:"many2many:{{mappedBy}}" json:"{{pluralize targetPropertyName}}"`
	{{/if}}
	{{/each}}
	{{/if}}
}

// TableName 指定 GORM 表名
func ({{className}}) TableName() string {
	return "{{tableName}}"
}
