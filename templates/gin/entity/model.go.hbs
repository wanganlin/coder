package model

import (
	"time"
)

// {{className}} {{tableComment}}
type {{className}} struct {
	{{#each columns}}
	{{#if (and ../features.auditFields (isAuditField this))}}
	// 审计字段 {{name}} 由中间件/GORM Hooks 自动填充
	{{else}}
	{{pascalCase name}} {{goType}} `gorm:"column:{{name}}{{#if isPrimaryKey}};primaryKey{{#if isAutoIncrement}};autoIncrement{{/if}}{{/if}}{{#unless nullable}};not null{{/unless}}" json:"{{propertyName name}}"`
	{{/if}}
	{{/each}}
}

// TableName 指定 GORM 表名
func ({{className}}) TableName() string {
	return "{{tableName}}"
}
