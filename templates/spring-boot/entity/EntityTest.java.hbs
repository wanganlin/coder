    @Test
    void shouldFindById() {
        {{#each columns}}{{#if isPrimaryKey}}var id = entity.get{{pascalCase name}}();{{/if}}{{/each}}
        when(repository.findById(any())).thenReturn(Optional.of(entity));

        Optional<{{className}}> result = service.findById(id);
        assertThat(result).isPresent();
        assertThat(result.get()).isEqualTo(entity);
    }

    @Test
    void shouldCreateEntity() {
        when(repository.save(any({{className}}.class))).thenReturn(entity);

        {{className}} result = service.save(entity);
