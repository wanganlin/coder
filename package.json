{
  "name": "@juling/coder",
  "version": "0.1.0",
  "description": "以数据模型为中心的多语言多框架代码生成引擎",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "coder": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "code-generator",
    "database",
    "scaffold",
    "spring-boot",
    "gin",
    "fastapi",
    "laravel",
    "nestjs"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/handlebars": "^4.0.40",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "handlebars": "^4.7.9",
    "mysql2": "^3.22.4",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.21.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
